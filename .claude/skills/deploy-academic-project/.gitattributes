# Ensure consistent line endings across platforms

# Force LF for shell scripts (critical for Docker/Linux compatibility)
*.sh text eol=lf

# Force LF for Dockerfiles
Dockerfile* text eol=lf

# Force LF for common config files
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
