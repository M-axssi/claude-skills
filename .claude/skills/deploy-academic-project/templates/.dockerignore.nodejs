# Node.js .dockerignore

# Version control
.git
.gitignore
.gitattributes

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Testing
coverage/
.nyc_output/
*.lcov

# Build output (will be copied from builder stage)
dist/
build/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Documentation
docs/
*.md
README*
LICENSE
CONTRIBUTING*

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Logs
logs/
*.log

# Environment variables (security)
.env
.env.local
.env.*.local
secrets/

# OS files
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp

# Package manager lock files (already copied separately)
# package-lock.json
# yarn.lock

# Optional npm cache
.npm/
.eslintcache

# Optional REPL history
.node_repl_history

# Serverless directories
.serverless/

# Webpack
.webpack/
